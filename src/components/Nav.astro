---
const currentPath = Astro.url.pathname;
---

<nav id="nav">
  <a href="/" class="nav-logo">
    <img src="/airlab-logo.png" alt="AIR Lab" />
  </a>
  <ul class="nav-links">
    <li><a href="/#platform" class={currentPath === '/' ? '' : ''}>RCP Platform</a></li>
    <li><a href="/#use-cases">Use Cases</a></li>
    <li><a href="/team" class={currentPath.startsWith('/team') ? 'nav-active' : ''}>Team</a></li>
    <li><a href="/news" class={currentPath.startsWith('/news') ? 'nav-active' : ''}>News</a></li>
    <li><a href="/partners" class={currentPath.startsWith('/partners') ? 'nav-active' : ''}>Partners</a></li>
    <li><a href="/contact" class={currentPath.startsWith('/contact') ? 'nav-active' : ''}>Contact</a></li>
    <li><a href="https://rcp-landing-page.rcp.pub.airlab.thalesdigital.io/" target="_blank" class="nav-cta">Log In to RCP</a></li>
  </ul>
</nav>

<style>
  .nav-active { color: #fff !important; }
</style>
