---
import Base from '../../layouts/Base.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';
import { client, newsAllQuery, imageUrl } from '../../lib/sanity';

export async function getStaticPaths() {
  const articles = await client.fetch(newsAllQuery);
  return articles
    .filter((a: any) => !a.externalUrl && a.slug?.current)
    .map((a: any) => ({ params: { slug: a.slug.current }, props: { article: a } }));
}

const { article } = Astro.props;

if (!article) {
  return Astro.redirect('/news');
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<Base title={article.title} description={article.excerpt}>
  <Nav slot="nav" />

  <div class="page-hero" style={(article.coverImageUrl || article.coverImage) ? `background-image: url('${article.coverImageUrl || imageUrl(article.coverImage, 1600)}'); background-size: cover; background-position: center;` : ''}>
    {(article.coverImageUrl || article.coverImage) && <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(11,26,47,0.82) 0%,rgba(6,113,129,0.5) 100%);"></div>}
    <div class="page-hero-content" style="max-width: 800px; position: relative; z-index: 1;">
      <div class="section-label">{article.category}</div>
      <h1 style="font-size: clamp(28px, 4vw, 52px);">{article.title}</h1>
      <p style="font-size: 14px; color: rgba(255,255,255,0.5); margin-top: 16px;">{formatDate(article.publishedAt)}</p>
    </div>
  </div>

  <section style="background: #fff; padding: 80px;">
    <div style="max-width: 760px; margin: 0 auto;">
      {article.excerpt && (
        <p style="font-size: 20px; line-height: 1.7; color: var(--muted); font-weight: 300; margin-bottom: 48px; border-left: 3px solid var(--teal); padding-left: 24px;">
          {article.excerpt}
        </p>
      )}
      {article.body?.map((block: any) => {
        if (block._type === 'block') {
          const style = block.style;
          const text = block.children?.map((c: any) => c.text).join('') || '';
          if (style === 'h2') return <h2 style="font-size: 24px; font-weight: 600; color: var(--navy); margin: 40px 0 16px; line-height: 1.3;">{text}</h2>;
          if (style === 'h3') return <h3 style="font-size: 19px; font-weight: 600; color: var(--navy); margin: 32px 0 12px;">{text}</h3>;
          if (!text) return null;
          return <p style="font-size: 16px; line-height: 1.8; color: var(--text); margin-bottom: 24px; font-weight: 300;">{text}</p>;
        }
        return null;
      })}
      <div style="margin-top: 64px; padding-top: 32px; border-top: 1px solid var(--border);">
        <a href="/news" class="btn-outline-navy">← Back to News</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Base>
